generator client {
  provider   = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organization {
  id        String    @id @default(uuid())
  name      String
  createdAt DateTime  @default(now())
  projects  Project[]
  teams     Team[]
  users     User[]
}

model User {
  id              String       @id @default(uuid())
  organizationId  String
  email           String       @unique
  passwordHash    String
  role            String       @default("user")
  lastLogin       DateTime?
  createdAt       DateTime     @default(now())
  projectsUpdated Project[]    @relation("UpdatedBy")
  syncLogs        SyncLog[]
  organization    Organization @relation(fields: [organizationId], references: [id])
}

model Project {
  id             String       @id @default(uuid())
  organizationId String
  name           String
  status         String
  budget         Decimal
  duration       Int
  totalHouses    Int
  config         Json
  version        Int          @default(1)
  updatedAt      DateTime     @updatedAt
  updatedById    String?
  deletedAt      DateTime?
  organization   Organization @relation(fields: [organizationId], references: [id])
  updatedBy      User?        @relation("UpdatedBy", fields: [updatedById], references: [id])
  zones          Zone[]
}

model Zone {
  id             String      @id @default(uuid())
  projectId      String
  organizationId String
  name           String
  version        Int         @default(1)
  updatedAt      DateTime    @updatedAt
  deletedAt      DateTime?
  households     Household[]
  project        Project     @relation(fields: [projectId], references: [id])
}

model Household {
  id             String    @id @default(uuid())
  zoneId         String
  organizationId String
  status         String
  location       Json
  owner          Json
  version        Int       @default(1)
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?
  zone           Zone      @relation(fields: [zoneId], references: [id])
}

model Team {
  id             String       @id @default(uuid())
  organizationId String
  name           String
  type           String
  status         String
  version        Int          @default(1)
  updatedAt      DateTime     @updatedAt
  deletedAt      DateTime?
  organization   Organization @relation(fields: [organizationId], references: [id])
}

model SyncLog {
  id        String   @id @default(uuid())
  userId    String
  deviceId  String
  timestamp DateTime @default(now())
  action    String
  details   Json
  user      User     @relation(fields: [userId], references: [id])
}

model deliveries {
  id                Int         @id @default(autoincrement())
  household_id      String?     @db.VarChar(200)
  agent             String?     @db.VarChar(200)
  date              DateTime?   @db.Timestamptz(6)
  type              String?     @db.VarChar(100)
  device_id         String?     @db.VarChar(200)
  signature         String?
  validation_status String?     @db.VarChar(100)
  duration_minutes  Int?
  notes             String?
  data              Json?       @default("{}")
  created_at        DateTime?   @default(now()) @db.Timestamptz(6)
  households        households? @relation(fields: [household_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([agent], map: "idx_deliveries_agent")
  @@index([date], map: "idx_deliveries_date")
  @@index([household_id], map: "idx_deliveries_household")
}

model households {
  id               String       @id @db.VarChar(200)
  project_id       String?      @db.VarChar(100)
  kobo_id          String?      @db.VarChar(200)
  zone             String?      @db.VarChar(200)
  commune          String?      @db.VarChar(200)
  village          String?      @db.VarChar(200)
  latitude         Float?
  longitude        Float?
  location         Json?        @default("{}")
  owner            Json?        @default("{}")
  status           String?      @default("Attente d?marrage") @db.VarChar(100)
  status_history   Json?        @default("[]")
  assigned_teams   Json?        @default("[]")
  material         Json?        @default("{}")
  delivery         Json?        @default("{}")
  work_time        Json?        @default("{}")
  progression      Float?       @default(0)
  etapes_realisees Json?        @default("[]")
  tech_info        Json?        @default("{}")
  notes            Json?        @default("[]")
  photos           Json?        @default("[]")
  created_at       DateTime?    @default(now()) @db.Timestamptz(6)
  updated_at       DateTime?    @default(now()) @db.Timestamptz(6)
  synced_at        DateTime?    @db.Timestamptz(6)
  deliveries       deliveries[]
  projects         projects?    @relation(fields: [project_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([commune], map: "idx_households_commune")
  @@index([kobo_id], map: "idx_households_kobo")
  @@index([project_id], map: "idx_households_project")
  @@index([status], map: "idx_households_status")
  @@index([zone], map: "idx_households_zone")
}

model projects {
  id         String       @id @db.VarChar(100)
  name       String       @db.VarChar(300)
  status     String?      @default("active") @db.VarChar(50)
  start_date DateTime?    @db.Date
  end_date   DateTime?    @db.Date
  config     Json?        @default("{}")
  created_at DateTime?    @default(now()) @db.Timestamptz(6)
  updated_at DateTime?    @default(now()) @db.Timestamptz(6)
  households households[]
  teams      teams[]
  zones      zones[]
}

model sync_logs {
  id            Int       @id @default(autoincrement())
  user_id       Int?
  type          String?   @db.VarChar(50)
  status        String?   @default("pending") @db.VarChar(50)
  records_count Int?      @default(0)
  data          Json?     @default("{}")
  error         String?
  created_at    DateTime? @default(now()) @db.Timestamptz(6)
  completed_at  DateTime? @db.Timestamptz(6)
  users         users?    @relation(fields: [user_id], references: [id], onUpdate: NoAction)

  @@index([user_id], map: "idx_sync_logs_user")
}

model teams {
  id            String    @id @db.VarChar(100)
  project_id    String?   @db.VarChar(100)
  zone_id       String?   @db.VarChar(100)
  name          String    @db.VarChar(200)
  type          String?   @db.VarChar(100)
  members_count Int?      @default(0)
  config        Json?     @default("{}")
  created_at    DateTime? @default(now()) @db.Timestamptz(6)
  projects      projects? @relation(fields: [project_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  zones         zones?    @relation(fields: [zone_id], references: [id], onUpdate: NoAction)
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model users {
  id            Int         @id @default(autoincrement())
  username      String      @unique @db.VarChar(100)
  password_hash String      @db.VarChar(255)
  display_name  String?     @db.VarChar(200)
  role          String?     @default("agent") @db.VarChar(50)
  is_active     Boolean?    @default(true)
  created_at    DateTime?   @default(now()) @db.Timestamptz(6)
  updated_at    DateTime?   @default(now()) @db.Timestamptz(6)
  sync_logs     sync_logs[]
}

model zones {
  id         String    @id @db.VarChar(100)
  project_id String?   @db.VarChar(100)
  name       String    @db.VarChar(300)
  code       String?   @db.VarChar(50)
  polygon    Json?
  config     Json?     @default("{}")
  created_at DateTime? @default(now()) @db.Timestamptz(6)
  teams      teams[]
  projects   projects? @relation(fields: [project_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}
